{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "DATABASE_URL": "@postgresql_url",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production"
  }
}
